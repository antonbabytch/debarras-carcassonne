---
const SITE_URL = 'https://debarras-carcassonne.fr';

const businessData = {
  "@context": "https://schema.org",
  "@type": "MovingCompany",
  "@id": `${SITE_URL}/#localbusiness`,
  "name": "Transport Carcassonne",
  "alternateName": "Débarras Carcassonne",
  "url": SITE_URL,
  "logo": `${SITE_URL}/favicon.svg`,
  "image": `${SITE_URL}/og-image.jpg`,
  "description": "Entreprise de débarras et vide maison à Carcassonne et dans l'Aude. Équipe locale de 3 professionnels, devis gratuit sous 2h, prix fixe garanti, valorisation des biens.",
  "telephone": "+33680873047",
  "email": "contact@debarras-carcassonne.fr",
  "priceRange": "€€",
  "currenciesAccepted": "EUR",
  "paymentAccepted": "Espèces, Carte bancaire, Virement",
  "knowsLanguage": ["fr-FR"],
  "foundingDate": "2021",
  "slogan": "Devis gratuit sous 2h, prix fixe garanti",
