---
// src/components/CTASection.astro
// CTA блок в конце страниц

export interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="cta-section">
  <div class="container">
    <div class="cta-content">
      <span class="mono-label">Nous contacter</span>
      <h2 class="display" set:html={title} />
      <p class="cta-sub">{subtitle}</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary btn-large">Demander un devis</a>
        <a href="tel:+33680873047" class="btn btn-outline-light btn-large">☎ 06 80 87 30 47</a>
      </div>
      <div class="cta-points">
        <span>✓ Visite et devis 100% gratuits</span>
        <span>✓ Réponse sous 2h en semaine</span>
        <span>✓ Aucun engagement</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: var(--bg-dark);
    color: var(--text-on-dark);
    padding: 120px 0;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    bottom: -30%;
    right: -10%;
    width: 50%;
    height: 100%;
    background: radial-gradient(circle at center, rgba(168, 112, 63, 0.10) 0%, transparent 60%);
    pointer-events: none;
  }
  .cta-content {
    position: relative;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }
  .cta-section .mono-label {
    color: var(--accent);
    margin-bottom: 24px;
    display: inline-block;
  }
  .cta-content h2 {
    font-size: clamp(40px, 5.2vw, 72px);
    line-height: 1.05;
    color: var(--text-on-dark);
    margin-bottom: 24px;
  }
  .cta-content h2 em {
    font-style: italic;
    color: var(--accent);
  }
  .cta-sub {
    font-size: 17px;
    color: var(--text-on-dark-muted);
    margin-bottom: 40px;
    line-height: 1.65;
  }
  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .cta-points {
    display: flex;
    gap: 32px;
    justify-content: center;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--text-on-dark-muted);
  }
  @media (max-width: 600px) {
    .cta-section { padding: 64px 0; }
    .cta-points { flex-direction: column; gap: 12px; }
  }
</style>