---
// src/components/ComboOffer.astro
// Баннер партнёрского предложения с transportcarcassonne.fr
// Используется на главной и на странице тарифов
---

<section class="combo">
  <div class="container combo__wrap">
    <div class="combo__head">
      <span class="combo__badge">OFFRE COMBO · −10 %</span>
      <h2 class="combo__title">
        Vous devez aussi <em>déménager</em> ?
      </h2>
      <p class="combo__sub">
        Confiez votre débarras à notre équipe <strong>et</strong> votre déménagement
        à notre partenaire
        <a href="https://transportcarcassonne.fr/" rel="noopener" data-track="sister_site_click" data-source="combo-debarras">
          Transport Carcassonne
        </a>.
        Vous bénéficiez de <strong>−10 % sur le débarras</strong> et d'un seul
        interlocuteur pour toute la logistique.
      </p>
    </div>

    <div class="combo__steps">
      <div class="combo__step">
        <span class="combo__num">1</span>
        <p>Devis débarras gratuit chez vous, sous 2&nbsp;h</p>
      </div>
      <div class="combo__step">
        <span class="combo__num">2</span>
        <p>Devis déménagement coordonné par Transport Carcassonne</p>
      </div>
      <div class="combo__step">
        <span class="combo__num">3</span>
        <p>Code <strong>COMBO10</strong> appliqué — économie immédiate</p>
      </div>
    </div>

    <div class="combo__cta">
      <a
        class="combo__btn combo__btn--primary"
        href="https://transportcarcassonne.fr/contact/?ref=debarras-combo"
        rel="noopener"
        data-track="combo_devis_click"
        data-source="combo-debarras"
      >
        Demander le devis combo →
      </a>
      <a
        class="combo__btn combo__btn--ghost"
        href="tel:+33629178237"
        data-track="phone_click"
        data-source="combo-debarras"
      >
        ☎ 06 29 17 82 37
      </a>
    </div>

    <p class="combo__note">
      Offre valable sur le devis débarras, à mentionner avant signature.
      Cumulable avec la valorisation des biens.
    </p>
  </div>
</section>

<style>
  .combo {
    padding: 80px 0;
    background: linear-gradient(135deg, var(--bg-dark) 0%, var(--bg-dark-alt) 100%);
    color: var(--text-on-dark);
    position: relative;
    overflow: hidden;
  }

  .combo::before {
    content: '';
    position: absolute;
    top: -30%;
    right: -10%;
    width: 50%;
    height: 160%;
    background: radial-gradient(circle at center, rgba(168, 112, 63, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .combo__wrap {
    position: relative;
    max-width: 980px;
  }

  .combo__head {
    text-align: center;
    margin-bottom: 48px;
  }

  .combo__badge {
    display: inline-block;
    background: var(--accent);
    color: var(--bg-dark);
    padding: 6px 16px;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    margin-bottom: 24px;
  }

  .combo__title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(34px, 4.8vw, 56px);
    font-weight: 400;
    line-height: 1.08;
    margin: 0 0 22px;
    color: var(--text-on-dark);
  }

  .combo__title em {
    font-style: italic;
    color: var(--accent);
  }

  .combo__sub {
    font-size: 17px;
    line-height: 1.65;
    max-width: 720px;
    margin: 0 auto;
    color: var(--text-on-dark-muted);
  }

  .combo__sub a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
  }

  .combo__sub a:hover {
    color: var(--text-on-dark);
  }

  .combo__sub strong {
    color: var(--text-on-dark);
    font-weight: 500;
  }

  .combo__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin: 48px 0;
  }

  .combo__step {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--line-dark);
    border-radius: 4px;
    padding: 28px 22px;
    text-align: center;
  }

  .combo__step p {
    margin: 14px 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-on-dark);
  }

  .combo__step p strong {
    color: var(--accent);
    font-weight: 600;
  }

  .combo__num {
    display: inline-flex;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg-dark);
    font-family: 'Instrument Serif', serif;
    font-size: 22px;
    align-items: center;
    justify-content: center;
  }

  .combo__cta {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 32px;
  }

  .combo__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 28px;
    border-radius: 4px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.2s, border-color 0.2s, color 0.2s;
    cursor: pointer;
  }

  .combo__btn:hover {
    transform: translateY(-1px);
  }

  .combo__btn--primary {
    background: var(--accent);
    color: var(--bg-dark);
  }

  .combo__btn--primary:hover {
    background: var(--accent-deep);
    color: var(--text-on-dark);
  }

  .combo__btn--ghost {
    background: transparent;
    color: var(--text-on-dark);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .combo__btn--ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--text-on-dark);
  }

  .combo__note {
    text-align: center;
    margin-top: 28px;
    font-size: 13px;
    color: var(--text-on-dark-muted);
    font-style: italic;
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .combo {
      padding: 64px 0;
    }
    .combo__steps {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .combo__cta {
      flex-direction: column;
      gap: 12px;
    }
    .combo__btn {
      width: 100%;
    }
  }
</style>
