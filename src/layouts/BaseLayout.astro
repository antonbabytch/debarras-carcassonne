---
// src/layouts/BaseLayout.astro
// Общий каркас всех страниц сайта

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import '../styles/global.css';

const SITE_URL = 'https://debarras-carcassonne.fr';
const GA_ID = 'G-L13KXVLMMY';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.jpg',
  noindex = false,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, SITE_URL).href;
const ogImageURL = ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE_URL).href;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="format-detection" content="telephone=no" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex, follow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:site_name" content="Débarras Carcassonne" />
  <meta property="og:locale" content="fr_FR" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <LocalBusinessSchema />

  <!-- Шрифты -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- Google Consent Mode v2 — denied by default; GA loads only after consent -->
  <script is:inline define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    window.gtag = gtag;
    gtag('consent', 'default', {
      ad_storage: 'denied', ad_user_data: 'denied', ad_personalization: 'denied',
      analytics_storage: 'denied', functionality_storage: 'granted', security_storage: 'granted',
      wait_for_update: 500
    });
    gtag('js', new Date());
    window.__loadGA = function () {
      if (window.__gaLoaded) return; window.__gaLoaded = true;
      var s = document.createElement('script');
      s.async = true; s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(s);
      gtag('config', GA_ID, { anonymize_ip: true });
    };
    window.__ccGrant = function () {
      try { localStorage.setItem('cc-consent', 'granted'); } catch (e) {}
      gtag('consent', 'update', { analytics_storage: 'granted' }); window.__loadGA();
    };
    window.__ccDeny = function () {
      try { localStorage.setItem('cc-consent', 'denied'); } catch (e) {}
      gtag('consent', 'update', { analytics_storage: 'denied' });
    };
    try { if (localStorage.getItem('cc-consent') === 'granted') { gtag('consent', 'update', { analytics_storage: 'granted' }); window.__loadGA(); } } catch (e) {}
  </script>

  <slot name="head" />
</head>
<body>
  <Header />

  <main>
    <slot />
  </main>

  <Footer />

  <a href="tel:+33629178237" class="floating-call" data-track="phone_click" data-source="floating">
    ☎ Appeler
  </a>

  <WhatsAppButton />

  <!-- Conversion tracking events -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Phone clicks (any <a href="tel:..."> на странице)
      document.querySelectorAll('a[href^="tel:"]').forEach(el => {
        el.addEventListener('click', () => {
          if (typeof gtag === 'function') {
            gtag('event', 'phone_click', {
              event_category: 'engagement',
              event_label: el.dataset.source || 'page',
              phone_number: el.getAttribute('href').replace('tel:', '')
            });
          }
        });
      });

      // WhatsApp clicks
      document.querySelectorAll('a[href*="wa.me"], a[href*="whatsapp.com"]').forEach(el => {
        el.addEventListener('click', () => {
          if (typeof gtag === 'function') {
            gtag('event', 'whatsapp_click', {
              event_category: 'engagement',
              event_label: el.dataset.source || 'page'
            });
          }
        });
      });

      // Form submits (Netlify forms)
      document.querySelectorAll('form[data-netlify="true"], form[name]').forEach(form => {
        form.addEventListener('submit', () => {
          if (typeof gtag === 'function') {
            gtag('event', 'form_submit', {
              event_category: 'lead',
              event_label: form.getAttribute('name') || 'unknown_form'
            });
          }
        });
      });
    });
  </script>

  <!-- Cookie consent banner (CNIL / Consent Mode v2) -->
  <style is:global>
    .cc-banner { position: fixed; left: 16px; right: 16px; bottom: 16px; z-index: 1000; max-width: 720px; margin: 0 auto;
      background: var(--bg-dark, #15191C); color: var(--text-on-dark, #FAFAF7); border: 1px solid var(--line-dark, #2D3338);
      border-radius: 12px; padding: 18px 20px; display: flex; gap: 16px; align-items: center; flex-wrap: wrap;
      box-shadow: 0 24px 60px -18px rgba(0,0,0,.6); }
    .cc-banner[hidden] { display: none; }
    .cc-text { font-size: 13.5px; line-height: 1.55; color: var(--text-on-dark-muted, #9CA3AC); flex: 1; min-width: 240px; margin: 0; }
    .cc-text a { color: var(--accent, #A8703F); text-decoration: underline; text-underline-offset: 2px; }
    .cc-actions { display: flex; gap: 10px; flex-shrink: 0; }
    .cc-btn { padding: 10px 18px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; border: 1px solid transparent; font-family: inherit; }
    .cc-btn--primary { background: var(--accent, #A8703F); color: #15100A; border-color: var(--accent, #A8703F); }
    .cc-btn--ghost { background: transparent; color: var(--text-on-dark, #FAFAF7); border-color: var(--line-dark, #2D3338); }
    .cc-btn--ghost:hover { border-color: var(--accent, #A8703F); }
    @media (max-width: 560px) { .cc-banner { flex-direction: column; align-items: stretch; } .cc-actions { justify-content: flex-end; } }
  </style>
  <div class="cc-banner" id="cc-banner" role="dialog" aria-label="Consentement aux cookies" hidden>
    <p class="cc-text">
      Nous utilisons des cookies de mesure d'audience (Google Analytics) pour améliorer le site.
      Ils ne sont déposés qu'avec votre accord. <a href="/politique-confidentialite">En savoir plus</a>.
    </p>
    <div class="cc-actions">
      <button type="button" class="cc-btn cc-btn--ghost" id="cc-refuse">Refuser</button>
      <button type="button" class="cc-btn cc-btn--primary" id="cc-accept">Accepter</button>
    </div>
  </div>
  <script is:inline>
    (function () {
      var b = document.getElementById('cc-banner'); if (!b) return;
      var stored = null; try { stored = localStorage.getItem('cc-consent'); } catch (e) {}
      if (!stored) b.removeAttribute('hidden');
      var a = document.getElementById('cc-accept'), r = document.getElementById('cc-refuse');
      a && a.addEventListener('click', function () { window.__ccGrant && window.__ccGrant(); b.setAttribute('hidden', ''); });
      r && r.addEventListener('click', function () { window.__ccDeny && window.__ccDeny(); b.setAttribute('hidden', ''); });
      window.__ccManage = function () { b.removeAttribute('hidden'); };
    })();
  </script>
</body>
</html>
