---
import ServicePageLayout from '../layouts/ServicePageLayout.astro';

const data = {
  pageTitle: 'Enlèvement d\'Encombrants à Carcassonne | Vieux Meubles, Électroménager',
  pageDescription: 'Enlèvement d\'encombrants à Carcassonne : vieux meubles, canapé, matelas, électroménager. Intervention rapide, à partir de 80 €.',

  overline: 'Notre service',
  title: 'Enlèvement<br/>d\'<em>encombrants</em><br/>à Carcassonne.',
  subtitle: 'Vous voulez vous débarrasser d\'un canapé, d\'une vieille armoire, d\'un matelas usagé ou d\'un frigo hors service ? Pas besoin de vider toute votre maison : nous nous déplaçons pour un seul objet ou quelques meubles, partout dans la région carcassonnaise.',

  priceFrom: 'à partir de 80 €',
  priceDesc: 'Pour 1 objet encombrant standard. Démontage si nécessaire, descente d\'étage, évacuation : tout est inclus dans le prix annoncé.',

  introTitle: 'Pourquoi faire appel<br/>à un <em>professionnel ?</em>',
