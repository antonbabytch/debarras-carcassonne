  `,

  casTitle: 'Tous les types <em>d\'encombrants.</em>',
  casSubtitle: 'Du petit meuble au piano droit, nous prenons en charge tous les objets encombrants.',
  cas: [
    { icon: '🛋', title: 'Mobilier', text: 'Canapés, fauteuils, banquettes, lits, sommiers, armoires, commodes, buffets, tables, chaises, bureaux, bibliothèques, étagères.' },
    { icon: '🛏', title: 'Literie', text: 'Matelas (toutes tailles), sommiers à lattes ou à ressorts, couettes, oreillers en grande quantité, surmatelas.' },
