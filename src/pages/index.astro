---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoPlaceholder from '../components/PhotoPlaceholder.astro';

const pageTitle = 'Débarras et Vide Maison à Carcassonne | Transport Carcassonne';
const pageDescription = 'Entreprise de débarras et vide maison à Carcassonne et dans l\'Aude. Devis gratuit sous 2h, prix fixe, valorisation de vos objets.';

const services = [
  {
    num: '01',
    type: 'Particuliers',
    title: 'Débarras<br/>de maison',
    desc: 'Vide maison complet : pièces de vie, cuisine, chambres. Démontage du mobilier, évacuation, nettoyage.',
    price: 'à partir de 1 200 €',
    href: '/debarras-maison',
  },
  {
    num: '02',
    type: 'Particuliers',
    title: 'Vide maison',
    desc: 'Spécialistes du vide maison après succession, départ en EHPAD, déménagement ou mise en vente.',
    price: 'à partir de 1 200 €',
    href: '/vide-maison',
  },
  {
    num: '03',
    type: 'Particuliers',
    title: 'Débarras<br/>d\'appartement',
    desc: 'Studio, T2, T3 ou plus : nous vidons votre appartement, étages avec ou sans ascenseur.',
    price: 'à partir de 350 €',
    href: '/debarras-appartement',
  },
  {
    num: '04',
    type: 'Sensible',
    title: 'Débarras<br/>après succession',
    desc: 'Accompagnement spécialisé après le décès d\'un proche : tri respectueux, mise de côté des souvenirs.',
    price: 'sur devis · souvent gratuit',
    href: '/debarras-succession',
  },
  {
    num: '05',
    type: 'Particuliers',
    title: 'Débarras<br/>de cave',
    desc: 'Vidage complet de cave, tri des objets, évacuation. Idéal avant une vente ou une rénovation.',
    price: 'à partir de 250 €',
    href: '/debarras-cave',
  },
  {
    num: '06',
    type: 'Particuliers',
    title: 'Débarras<br/>de garage',
    desc: 'Outils, vélos, vieux meubles, cartons : nous vidons votre garage de fond en comble.',
    price: 'à partir de 300 €',
    href: '/debarras-garage',
  },
  {
    num: '07',
    type: 'Particuliers',
    title: 'Débarras<br/>de grenier',
    desc: 'Évacuation rapide de greniers et combles, même difficiles d\'accès. Recherche minutieuse des objets de valeur.',
    price: 'à partir de 250 €',
    href: '/debarras-grenier',
  },
  {
    num: '08',
    type: 'Ponctuel',
    title: 'Enlèvement<br/>d\'encombrants',
    desc: 'Un seul meuble ou quelques objets : intervention rapide pour mobilier, électroménager, matelas.',
    price: 'à partir de 80 €',
    href: '/enlevement-encombrants',
  },
];

const formules = [
  {
    num: '01',
    title: 'Débarras<br/>Standard',
    desc: 'Tarif classique au m³, appliqué quand le logement contient principalement des encombrants sans valeur marchande.',
    highlight: false,
  },
  {
    num: '02',
    title: 'Débarras<br/>Réduit',
    desc: 'Remise de 20 à 50 %. Mobilier de qualité, électroménager récent, objets vintage : leur valeur est déduite du devis.',
    highlight: false,
  },
  {
    num: '03',
    title: 'Débarras<br/>Gratuit',
    desc: 'Vous ne payez rien. La valeur des biens couvre nos frais. Cas fréquent pour les successions de logements bien équipés.',
    highlight: true,
  },
  {
    num: '04',
    title: 'Débarras<br/>Indemnisé',
    desc: 'Nous vous versons une indemnité. La valeur des biens dépasse le coût de l\'intervention. Réservé aux logements avec antiquités.',
    highlight: false,
  },
];

const process = [
  { num: '01', title: 'Votre demande', desc: 'Vous nous appelez ou remplissez le formulaire. Nous fixons un rendez-vous selon vos disponibilités.' },
  { num: '02', title: 'Visite gratuite', desc: 'Visite chez vous (ou évaluation par photos) sous 24h. Estimation du volume et des objets valorisables.' },
  { num: '03', title: 'Devis fixe', desc: 'Devis détaillé avec prix garanti par contrat. Aucun frais caché, aucun acompte demandé.' },
  { num: '04', title: 'Intervention', desc: 'Notre équipe vide votre logement. Vous recevez bordereau de suivi et facture en fin de prestation.' },
];

const cities = [
  { name: 'Carcassonne', main: true, href: '/debarras-carcassonne' },
  { name: 'Trèbes', main: true, href: '/debarras-trebes' },
  { name: 'Limoux', main: true, href: '/debarras-limoux' },
  { name: 'Castelnaudary', main: true, href: '/debarras-castelnaudary' },
  { name: 'Narbonne', main: true, href: '/debarras-narbonne' },
  { name: 'Lézignan-Corbières', main: false, href: '#' },
  { name: 'Cazilhac', main: false, href: '#' },
  { name: 'Pennautier', main: false, href: '#' },
  { name: 'Villemoustaussou', main: false, href: '#' },
  { name: 'Berriac', main: false, href: '#' },
  { name: 'Cavanac', main: false, href: '#' },
  { name: 'Palaja', main: false, href: '#' },
  { name: 'Villegailhenc', main: false, href: '#' },
  { name: 'Conques-sur-Orbiel', main: false, href: '#' },
  { name: 'Bram', main: false, href: '#' },
  { name: 'Capendu', main: false, href: '#' },
  { name: 'Caunes-Minervois', main: false, href: '#' },
  { name: 'Rieux-Minervois', main: false, href: '#' },
  { name: 'Pezens', main: false, href: '#' },
  { name: 'Alzonne', main: false, href: '#' },
];

const testimonials = [
  {
    quote: 'Après le décès de ma mère, je redoutais de m\'occuper de sa maison à Trèbes. L\'équipe a été d\'une grande discrétion et d\'un grand professionnalisme. Tout a été fait en deux jours.',
    name: 'Marie L.',
    meta: 'Trèbes — Succession',
  },
  {
    quote: 'Devis tenu au centime près, équipe ponctuelle. Ils ont même racheté plusieurs meubles anciens, ce qui a réduit ma facture de moitié. Service au top.',
    name: 'Jean-Pierre M.',
    meta: 'Carcassonne — Vide maison',
  },
  {
    quote: 'Je devais vider rapidement l\'appartement d\'un locataire. Intervention sous 48h, devis clair, fourgon plein en quelques heures. Parfait pour un propriétaire.',
    name: 'Sophie D.',
    meta: 'Carcassonne — Débarras appartement',
  },
];

const marquee = [
  'Débarras maison', 'Vide maison', 'Débarras appartement', 'Succession',
  'Cave & garage', 'Grenier', 'Encombrants', 'Local commercial', 'Syndrome de Diogène',
];
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="overline mono-label">Entreprise de débarras dans l'Aude</div>
      <div class="hero-grid">
        <div>
          <h1 class="display hero-title">
            Débarras et<br/>
            vide maison à<br/>
            <em>Carcassonne.</em>
          </h1>
          <p class="hero-sub">
            Une équipe locale de trois professionnels intervient dans toute
            la région, de Carcassonne à Narbonne. Devis gratuit sous 2h, prix
            fixe garanti, valorisation de vos biens.
          </p>
          <div class="hero-actions">
            <a href="#contact" class="btn btn-primary btn-large">Demander un devis</a>
            <a href="#services" class="btn btn-outline-light btn-large">Nos services</a>
          </div>
        </div>
        <div class="hero-side">
          <div class="hero-side-photo">
            <PhotoPlaceholder
              aspectRatio="4/3"
              label="Photo équipe"
              description="L'équipe de 3 professionnels devant le fourgon"
              variant="dark"
            />
          </div>
          <div class="hero-side-stat">
            <div class="stat-num">2<sup>h</sup></div>
            <div class="stat-label">Réponse à votre demande<br/>en semaine</div>
          </div>
          <div class="hero-side-stat">
            <div class="stat-num">5<sup>ans</sup></div>
            <div class="stat-label">D'expérience dans le débarras<br/>et le vide maison</div>
          </div>
          <div class="hero-side-stat">
            <div class="stat-num">160<sup>m³</sup></div>
            <div class="stat-label">D'entrepôt pour valoriser<br/>vos biens</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Marquee -->
    <div class="hero-strip">
      <div class="hero-strip-inner">
        <span>
          {marquee.map((item) => (
            <>{item} <span class="dot">·</span></>
          ))}
        </span>
        <span>
          {marquee.map((item) => (
            <>{item} <span class="dot">·</span></>
          ))}
        </span>
      </div>
    </div>
  </section>

  <!-- ============ ENGAGEMENT ============ -->
  <section class="engagement">
    <div class="container">
      <div class="eng-grid">
        <div class="eng-left">
          <span class="mono-label">Notre métier</span>
          <h2 class="display">Une équipe locale,<br/>au service des familles<br/>et des <em>professionnels.</em></h2>
          <p>
            Transport Carcassonne est une entreprise de débarras et vide maison
            basée à Carcassonne, dans l'Aude. Notre équipe intervient dans
            toute la région carcassonnaise dans un rayon de 40 km, ainsi qu'à
            Narbonne et Lézignan-Corbières.
          </p>
          <p>
            Avec deux fourgons et un entrepôt de 160 m³, nous assurons le
            débarras complet de votre bien immobilier — et grâce à notre
            expertise dans la valorisation des biens, votre facture peut
            être considérablement réduite, voire annulée.
          </p>
        </div>
        <div class="eng-stats">
          <div class="eng-stat">
            <span class="eng-stat-num">3</span>
            <span class="eng-stat-label">Professionnels<br/>expérimentés</span>
          </div>
          <div class="eng-stat">
            <span class="eng-stat-num">2</span>
            <span class="eng-stat-label">Fourgons<br/>12 m³ et 20 m³</span>
          </div>
          <div class="eng-stat">
            <span class="eng-stat-num">160</span>
            <span class="eng-stat-label">m³ d'entrepôt pour<br/>la valorisation</span>
          </div>
          <div class="eng-stat">
            <span class="eng-stat-num">40</span>
            <span class="eng-stat-label">km de zone<br/>d'intervention</span>
          </div>
        </div>
      </div>
      <div class="eng-photo-row">
        <PhotoPlaceholder
          aspectRatio="21/9"
          label="Entrepôt 160 m³"
          description="Vue de l'entrepôt de valorisation à Carcassonne"
          variant="light"
        />
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="services" id="services">
    <div class="container">
      <div class="section-header">
        <h2 class="display">Nos <em>prestations.</em></h2>
        <p>
          Que vous soyez particulier ou professionnel, nous prenons en charge
          tous types de débarras dans la région de Carcassonne. Cliquez sur
          chaque service pour en savoir plus.
        </p>
      </div>
      <div class="services-grid">
        {services.map((s) => (
          <a href={s.href} class="service">
            <div class="service-num">— {s.num} / {s.type}</div>
            <h3 set:html={s.title} />
            <p>{s.desc}</p>
            <div class="service-price">{s.price}</div>
            <span class="service-link">En savoir plus</span>
          </a>
        ))}
        <a href="/contact" class="service dark">
          <div class="service-num">— Cas particulier ?</div>
          <h3>Décrivez<br/>votre situation.</h3>
          <p>Local commercial, syndrome de Diogène, situations complexes : en cinq ans, nous avons vu presque tout. Nous trouverons une solution.</p>
          <span class="service-link">Nous contacter</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ EN IMAGES ============ -->
  <section class="en-images">
    <div class="container">
      <div class="section-header">
        <h2 class="display">Le débarras en <em>images.</em></h2>
        <p>
          Maisons, appartements, caves, greniers : voici quelques exemples
          de nos interventions dans la région de Carcassonne.
        </p>
      </div>
      <div class="photo-grid">
        <div class="photo-grid-main">
          <PhotoPlaceholder
            aspectRatio="4/3"
            label="Avant / Après"
            description="Maison complète vidée — Carcassonne centre"
            variant="light"
          />
        </div>
        <div class="photo-grid-side">
          <PhotoPlaceholder
            aspectRatio="1/1"
            label="Fourgon 20 m³"
            description="Chargement d'un appartement T4"
            variant="light"
          />
          <PhotoPlaceholder
            aspectRatio="1/1"
            label="Tri & valorisation"
            description="Mobilier ancien sélectionné pour revente"
            variant="light"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FORMULES ============ -->
  <section class="formules" id="formules">
    <div class="container">
      <div class="section-header">
        <h2 class="display">Quatre formules,<br/>une <em>logique simple.</em></h2>
        <p>
          Notre entrepôt et notre expertise dans la valorisation des biens
          nous permettent de proposer une approche unique : votre débarras
          peut être réduit, gratuit, voire rémunéré.
        </p>
      </div>
      <div class="formules-grid">
        {formules.map((f) => (
          <div class={f.highlight ? 'formule highlight' : 'formule'}>
            <div class="formule-number">— Formule {f.num}</div>
            <h3 set:html={f.title} />
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PROCESS ============ -->
  <section class="process" id="process">
    <div class="container">
      <div class="section-header">
        <h2 class="display">Notre <em>méthode.</em></h2>
        <p>
          Un processus simple et transparent en quatre étapes. Aucun acompte,
          aucune surprise : le prix annoncé dans le devis est le prix final,
          garanti par contrat.
        </p>
      </div>
      <div class="process-grid">
        {process.map((p) => (
          <div class="process-step">
            <div class="step-num">— Étape {p.num}</div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ ZONE ============ -->
  <section class="zone" id="zone">
    <div class="container">
      <div class="zone-grid">
        <div class="zone-left">
          <span class="mono-label">Notre territoire</span>
          <h2 class="display">L'Aude,<br/>de Carcassonne<br/>à <em>Narbonne.</em></h2>
          <p>
            Transport Carcassonne intervient dans un rayon de 40 km autour
            de Carcassonne, ainsi qu'à Narbonne et Lézignan-Corbières. Le
            déplacement pour la visite d'évaluation est totalement gratuit,
            quelle que soit votre commune.
          </p>
          <p>
            Cliquez sur votre commune pour découvrir notre page dédiée
            et nos spécificités locales.
          </p>
        </div>
        <div class="zone-cities">
          {cities.map((c) => (
            <a href={c.href} class={c.main ? 'zone-city main' : 'zone-city'}>
              {c.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="testimonials">
    <div class="container">
      <div class="section-header">
        <h2 class="display">Ils nous ont fait<br/><em>confiance.</em></h2>
        <p>
          Particuliers, héritiers, propriétaires bailleurs, notaires :
          nos clients témoignent de leur expérience.
        </p>
      </div>
      <div class="testimonials-grid">
        {testimonials.map((t) => (
          <div class="testimonial">
            <span class="quote-mark">"</span>
            <p>{t.quote}</p>
            <div class="testimonial-author">
              <div class="testimonial-name">{t.name}</div>
              <div class="testimonial-meta">{t.meta}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA + FORM ============ -->
  <section class="cta" id="contact">
    <div class="container">
      <div class="cta-grid">
        <div>
          <span class="mono-label">Nous contacter</span>
          <h2 class="display">Parlons de<br/><em>votre situation.</em></h2>
          <p class="cta-info">
            Appelez-nous, écrivez sur WhatsApp ou remplissez le formulaire.
            Nous vous répondons sous 2h en semaine pour fixer un rendez-vous
            d'évaluation gratuit, sans engagement.
          </p>
          <div class="cta-channels">
            <div class="channel">
              <div class="channel-label">Téléphone</div>
              <a href="tel:+33626178237" class="channel-value">06 26 17 82 37</a>
            </div>
            <div class="channel">
              <div class="channel-label">WhatsApp</div>
              <a href="#" class="channel-value">06 26 17 82 37</a>
            </div>
            <div class="channel">
              <div class="channel-label">Email</div>
              <a href="mailto:contact@debarras-carcassonne.fr" class="channel-value">contact@debarras-carcassonne.fr</a>
            </div>
            <div class="channel">
              <div class="channel-label">Horaires</div>
              <span class="channel-value">Lun–Sam · 8h–19h</span>
            </div>
          </div>
        </div>

        <form
          class="form"
          name="devis-gratuit"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/merci"
        >
          <input type="hidden" name="form-name" value="devis-gratuit" />
          <p hidden><label>Не заполнять: <input name="bot-field" /></label></p>

          <div class="form-title">Devis gratuit</div>
          <div class="form-sub">Réponse sous 2h en semaine, sans engagement.</div>

          <input type="text" name="nom" placeholder="Votre nom" required />
          <input type="tel" name="telephone" placeholder="Téléphone" required />

          <select name="service" required>
            <option value="">Type de débarras</option>
            <option value="Maison">Maison</option>
            <option value="Appartement">Appartement</option>
            <option value="Garage">Garage</option>
            <option value="Cave">Cave</option>
            <option value="Grenier">Grenier</option>
          </select>

          <select name="urgence" required>
            <option value="">Délai</option>
            <option value="En urgence (sous 48h)">En urgence (sous 48h)</option>
            <option value="Dans la semaine">Dans la semaine</option>
            <option value="Pas urgent">Pas urgent</option>
          </select>

          <textarea name="message" placeholder="Précisions (optionnel)"></textarea>

          <button type="submit" class="btn btn-primary">Devis gratuit</button>
          <div class="form-note">
            Vos données sont uniquement utilisées pour traiter votre
            demande, conformément au RGPD.
          </div>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============ HERO ============ */
  .hero {
    background: var(--bg-dark);
    color: var(--text-on-dark);
    padding: 100px 0 0;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    right: -20%;
    width: 60%;
    height: 100%;
    background: radial-gradient(circle at center, rgba(168, 112, 63, 0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
  }
  .overline {
    color: var(--accent);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .overline::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--accent);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 80px;
    align-items: start;
    padding-bottom: 100px;
  }
  .hero-title {
    font-size: clamp(48px, 7.2vw, 104px);
    margin-bottom: 36px;
    color: var(--text-on-dark);
  }
  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }
  .hero-sub {
    font-size: 18px;
    color: var(--text-on-dark-muted);
    max-width: 560px;
    margin-bottom: 40px;
    line-height: 1.6;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-side {
    border-left: 1px solid var(--line-dark);
    padding-left: 40px;
    padding-bottom: 16px;
  }
  .hero-side-photo {
    margin-bottom: 32px;
  }
  .hero-side-stat {
    margin-bottom: 36px;
  }
  .hero-side-stat:last-child { margin-bottom: 0; }
  .stat-num {
    font-family: 'Instrument Serif', serif;
    font-size: 64px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
    color: var(--text-on-dark);
  }
  .stat-num sup {
    font-size: 22px;
    color: var(--accent);
    margin-left: 4px;
    vertical-align: super;
    font-style: italic;
  }
  .stat-label {
    font-size: 13px;
    color: var(--text-on-dark-muted);
    line-height: 1.5;
  }

  .hero-strip {
    border-top: 1px solid var(--line-dark);
    padding: 22px 0;
    overflow: hidden;
  }
  .hero-strip-inner {
    display: flex;
    gap: 60px;
    white-space: nowrap;
    animation: scroll 50s linear infinite;
    color: var(--text-on-dark-muted);
    font-size: 14px;
  }
  .hero-strip-inner > span {
    display: flex;
    align-items: center;
    gap: 60px;
    padding-right: 60px;
  }
  .hero-strip .dot {
    color: var(--accent);
  }
  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (max-width: 900px) {
    .hero { padding: 56px 0 0; }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      padding-bottom: 56px;
    }
    .hero-side {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--line-dark);
      padding-top: 32px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .hero-side-stat {
      margin-bottom: 0;
      padding-right: 12px;
      border-right: 1px solid var(--line-dark);
    }
    .hero-side-stat:last-child {
      border-right: none;
      padding-right: 0;
    }
    .stat-num {
      font-size: 40px;
      margin-bottom: 6px;
    }
    .stat-num sup { font-size: 16px; }
    .stat-label { font-size: 11px; line-height: 1.4; }
    .hero-actions .btn { flex: 1; justify-content: center; }
  }

